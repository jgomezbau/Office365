{
  "name": "Microsoft365Copilot",
  "version": "2.6.0",
  "description": "Aplicación de escritorio moderna para Microsoft 365 Copilot",
  "author": "Juan Bau <jgomezbau@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:appimage": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:linux": "electron-builder --linux AppImage deb tar.gz"
  },
  "build": {
    "appId": "Microsoft-365-Copilot",
    "productName": "Microsoft 365 Copilot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "icons/**/*",
      "config.xml"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "icon": "icons/icon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.11",
    "electron-store": "^11.0.2"
  }
}
