{
  "name": "o365linuxdesktop",
  "version": "2.6.1",
  "description": "Aplicación de escritorio moderna para Microsoft 365 en Linux",
  "author": "Juan Bau <jgomezbau@gmail.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron . --ozone-platform=x11",
    "build": "electron-builder",
    "build:appimage": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:linux": "electron-builder --linux AppImage deb tar.gz"
  },
  "build": {
    "appId": "com.jgomezbau.o365linuxdesktop",
    "productName": "O365 Linux Desktop",
    "artifactName": "o365linuxdesktop-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "icons/**/*",
      "config.xml"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "icon": "icons/icon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.11",
    "electron-store": "^11.0.2"
  }
}
